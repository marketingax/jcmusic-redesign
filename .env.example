# Copy to .env.local for local dev. NEVER commit the real .env.local.
# In production these are set as Vercel Environment Variables.

# GoHighLevel Private Integration Token (rotate here when needed)
GHL_PRIVATE_TOKEN=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# GHL location (sub-account) id
GHL_LOCATION_ID=

# GHL calendar id (used for the appointments view)
GHL_CALENDAR_ID=

# Admin dashboard login password (choose a strong one)
ADMIN_PASSWORD=

# Random string used to sign session cookies (e.g. `openssl rand -hex 32`)
SESSION_SECRET=
